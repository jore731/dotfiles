{
  "mcpServers": {
    "figma": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "headers": {},
      "source": "user",
      "sourcePath": "/Users/jorgepulidolopez/.copilot/mcp-config.json"
    },
    "azure-mcp": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ],
      "source": "user",
      "sourcePath": "/Users/jorgepulidolopez/.copilot/mcp-config.json"
    },
    "kubernetes": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "kubernetes-mcp-server@latest"
      ],
      "source": "user",
      "sourcePath": "/Users/jorgepulidolopez/.copilot/mcp-config.json"
    },
    "drawio": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@drawio/mcp"
      ],
      "source": "user",
      "sourcePath": "/Users/jorgepulidolopez/.copilot/mcp-config.json"
    },
    "gitlab": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@zereight/mcp-gitlab",
        "--token=${ROQS_GITLAB_TOKEN}",
        "--api-url=https://gitlab.roqs.basf.net/api/v4"
      ],
      "source": "user",
      "sourcePath": "/Users/jorgepulidolopez/.copilot/mcp-config.json"
    },
    "azure-devops": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "rgqds",
        "--authentication",
        "pat"
      ],
      "env": {
        "PERSONAL_ACCESS_TOKEN": "${RGQDS_AZURE_DEVOPS_PAT_B64}"
      },
      "source": "user",
      "sourcePath": "/Users/jorgepulidolopez/.copilot/mcp-config.json"
    },
    "obsidian": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "https://127.0.0.1:27124/mcp/",
      "headers": {
        "Authorization": "Bearer ${OBSIDIAN_REST_API_KEY}"
      },
      "source": "user",
      "sourcePath": "/Users/jorgepulidolopez/.copilot/mcp-config.json"
    },
    "confluence": {
      "type": "local",
      "command": "uvx",
      "tools": [
        "*"
      ],
      "args": [
        "mcp-atlassian",
        "-v",
        "--confluence-url",
        "https://confluence.basf.net",
        "--confluence-username",
        "${CONFLUENCE_USERNAME}",
        "--confluence-token",
        "${CONFLUENCE_TOKEN}",
        "--no-confluence-ssl-verify",
        "--toolsets",
        "default"
      ]
    }
  }
}