{
  "mcpServers": {
    "figma": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp",
      "headers": {}
    },
    "kubernetes": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "kubernetes-mcp-server@latest"
      ]
    },
    "drawio": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@drawio/mcp"
      ]
    },
    "gitlab": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@zereight/mcp-gitlab",
        "--token=${ROQS_GITLAB_TOKEN}",
        "--api-url=https://gitlab.roqs.basf.net/api/v4"
      ]
    },
    "azure-devops": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "rgqds",
        "--authentication",
        "pat"
      ],
      "env": {
        "PERSONAL_ACCESS_TOKEN": "${RGQDS_AZURE_DEVOPS_PAT_B64}"
      }
    },
    "obsidian": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "https://127.0.0.1:27124/mcp",
      "headers": {
        "Authorization": "Bearer ${OBSIDIAN_REST_API_KEY}"
      }
    },
    "confluence": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "uvx",
      "args": [
        "mcp-atlassian",
        "-v",
        "--confluence-url",
        "https://confluence.basf.net",
        "--confluence-username",
        "${CONFLUENCE_USERNAME}",
        "--confluence-token",
        "${CONFLUENCE_TOKEN}",
        "--no-confluence-ssl-verify",
        "--toolsets",
        "default"
      ]
    },
    "blender": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "uv",
      "args": [
        "--directory",
        "$HOME/blender_mcp/mcp",
        "run",
        "blender-mcp"
      ],
      "env": {
        "BLENDER_PATH": "/Applications/Blender.app/Contents/MacOS/Blender"
      }
    },
    "playwright": {
      "tools": [
        "*"
      ],
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--isolated"
      ]
    },
    "homeassistant": {
      "tools": [
        "*"
      ],
      "type": "http",
      "url": "https://homeassistant.quokka-polaris.ts.net/api/mcp",
      "headers": {
        "Authorization": "Bearer ${HOMEASSISTANT_TOKEN}"
      }
    }
  }
}
