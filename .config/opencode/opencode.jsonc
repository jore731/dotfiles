{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": "allow",
    "task": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "pwd": "allow",
      "git status*": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "rm -rf *": "deny",
      "rm -fr *": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny"
    },
    "external_directory": {
      "*": "deny",
      "~/**": "ask"
    }
  }
}
