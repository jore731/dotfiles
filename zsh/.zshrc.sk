# sk profile — isolated Azure / Kubernetes / GitHub CLI state.
export AZURE_CONFIG_DIR="$XDG_CONFIG_HOME/azure-profiles/sk"
export KUBECONFIG="$HOME/.kube/profiles/sk/config"
export GH_CONFIG_DIR="$XDG_CONFIG_HOME/gh-profiles/sk"
mkdir -p "$AZURE_CONFIG_DIR" "${KUBECONFIG:h}" "$GH_CONFIG_DIR"

