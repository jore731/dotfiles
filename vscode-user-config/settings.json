{
    // Vscode style settings
    "workbench.colorTheme": "Dark+",
    "window.title": "${dirty}${rootNameShort}",
    "editor.tokenColorCustomizations": {
        "[*Light*]": {
            "textMateRules": [
                {
                    "scope": "ref.matchtext",
                    "settings": {
                        "foreground": "#000"
                    }
                }
            ]
        },
        "[*Dark*]": {
            "textMateRules": [
                {
                    "scope": "ref.matchtext",
                    "settings": {
                        "foreground": "#fff"
                    }
                }
            ]
        }
    },
    "workbench.tree.indent": 10,
    "workbench.tree.renderIndentGuides": "always",
    // VSCode saving behavior
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true,
    // Jupyter
    "jupyter.askForKernelRestart": false,
    "jupyter.widgetScriptSources": [
        "jsdelivr.com",
        "unpkg.com"
    ],
    "notebook.output.textLineLimit": 60,
    // Git settings
    "git.rebaseWhenSync": true,
    "git.autoStash": true,
    "git.confirmSync": false,
    "git.autofetch": true,
    "git.blame.statusBarItem.enabled": false,
    "git.replaceTagsWhenPull": true,
    // Formatters
    "[terraform]": {
        "editor.defaultFormatter": "hashicorp.terraform"
    },
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        },
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    // Editor settings
    "editor.accessibilitySupport": "off",
    "files.exclude": {
        "**/__pycache__": true,
        "**/.cache": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true
    },
    // Python settings
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.extraPaths": [
        "src"
    ],
    "python.testing.pytestArgs": [
        "--disable-warnings"
    ],
    "python.analysis.inlayHints.pytestParameters": true,
    "python.autoComplete.extraPaths": [],
    "python.analysis.autoSearchPaths": false,
    // Remote Development settings
    "remote.otherPortsAttributes": {
        "onAutoForward": "notify"
    },
    "remote.autoForwardPortsSource": "hybrid",
    "remote.SSH.connectTimeout": 1800,
    // Docker settings
    "dev.containers.dockerPath": "podman",
    // Github settings
    "github-actions.workflows.pinned.refresh.enabled": true,
    "githubPullRequests.pullBranch": "never",
    // Copilot settings
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "scminput": false
    },
    // YAML schemas
    "yaml.schemas": {
        "https://raw.githubusercontent.com/okteto/okteto/master/schema.json": [
            "okteto.yml",
            "okteto.yaml"
        ]
    },
    // JSON schemas
    "json.schemas": [
        {
            "fileMatch": [
                "devbox.json"
            ],
            "url": "https://raw.githubusercontent.com/jetpack-io/devbox/main/.schema/devbox.schema.json"
        }
    ],
    // Editor settings
    "editor.fontFamily": "'Fira Code', 'Hack Nerd Font'",
    "editor.fontLigatures": true,
    "window.openFoldersInNewWindow": "on",
    // Terminal settings
    "terminal.integrated.profiles.osx": {
        "devboxCompatibleShell": {
            "path": "/bin/zsh",
            "args": []
        }
    },
    "terminal.integrated.fontFamily": "'monospace', 'Hack Nerd Font'",
    // File handling settings 
    "security.promptForLocalFileProtocolHandling": false,
    "files.eol": "\n",
    // Markdown settings
    "workbench.editorAssociations": {
        "*.md": "vscode.markdown.preview.editor"
    },
    // Miscellaneous settings
    "diffEditor.ignoreTrimWhitespace": false,
    "github.copilot.nextEditSuggestions.enabled": true,
    "git.blame.editorDecoration.enabled": true,
    "remote.SSH.remotePlatform": {
        "coder-vscode.coder.ds.basf.net--pulidoJ--black-barracuda-57.main": "linux",
        "coder-vscode.coder.ds.basf.net--pulidoJ--red-squid-60.main": "linux",
        "coder-vscode.coder.ds.basf.net--pulidoj--red-squid-60.main": "linux",
        "coder-vscode.coder.ds.basf.net--pulidoJ--test-env.main": "linux",
        "coder-vscode.coder.ds.basf.net--pulidoJ--amber-damselfly-23.main": "linux",
        "coder-vscode.coder.ds.basf.net--pulidoJ--rdcp-iac.main": "linux"
    },
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "vs-kubernetes": {
        "vs-kubernetes.crd-code-completion": "enabled"
    },
    "chat.agent.maxRequests": 100,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "terminal.integrated.suggest.cdPath": "off",
    "terminal.integrated.suggest.enabled": false,
    "okteto.upTimeout": 60,
    "remote.SSH.serverInstallPath": {
        "skqual-celery-ai.okteto": "/tmp/vscode-server",
        "skprod-celery-ai.okteto": "/tmp/vscode-server"
    },
    "chat.viewSessions.orientation": "stacked",
    "ruff.path": [
        "uvx ruff"
    ],
    "devbox.autoShellOnTerminal": false,
    "github.copilot.chat.copilotMemory.enabled": true,
    "github.copilot.selectedCompletionModel": "GPT-5.1-Codex-Max",
    "azureResourceGroups.duplicateSubscriptionMode": true,
    "@azure.argTenant": "ecaa386b-c8df-4ce0-ad01-740cbdb5ba55",
    "devbox.enableDebugMode": true,
    "json.schemaDownload.trustedDomains": {
        "https://developer.microsoft.com/json-schemas/": true,
        "https://json-schema.org/": true,
        "https://json.schemastore.org/": true,
        "https://raw.githubusercontent.com": true,
        "https://raw.githubusercontent.com/devcontainers/spec/": true,
        "https://raw.githubusercontent.com/microsoft/vscode/": true,
        "https://schemastore.azurewebsites.net/": true,
        "https://www.schemastore.org/": true
    },
    "hediet.vscode-drawio.resizeImages": null,
}